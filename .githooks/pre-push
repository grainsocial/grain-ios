#!/bin/sh

# Git LFS
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs pre-push "$@"

# Check formatting and lint (full project, quiet unless issues found)
FORMAT_OUT=$(swiftformat Grain GrainTests --lint 2>/dev/null | grep -v "^SwiftFormat\|^Reading\|^0/")
[ -n "$FORMAT_OUT" ] && echo "$FORMAT_OUT" && echo "⚠ Run 'just format-fix' to fix."

LINT_OUT=$(swiftlint lint Grain GrainTests 2>/dev/null | grep -v "^Linting\|^Done linting")
[ -n "$LINT_OUT" ] && echo "$LINT_OUT"

exit 0
