# Copy this file to .env and fill in your values
# .env is gitignored and never committed

# Apple Developer Team ID (find at developer.apple.com → Account → Membership)
APPLE_TEAM_ID=XXXXXXXXXX
# Bundle identifier — defaults to social.grain.grain if unset
BUNDLE_ID=social.grain.grain
# Product name — required for the build to produce Grain.app (an empty value
# breaks `just generate` with a "Multiple commands produce '.app'" error)
BUNDLE_NAME=Grain
# Simulator UDID to target with `just sim`
SIM_UDID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
