# Copy this file to .env and fill in your values
# .env is gitignored and never committed

# Apple Developer Team ID (find at developer.apple.com → Account → Membership)
APPLE_TEAM_ID=XXXXXXXXXX
# Bundle identifier — defaults to social.grain.grain if unset
BUNDLE_ID=social.grain.grain
# Simulator UDID to target with `just sim`
SIM_UDID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
