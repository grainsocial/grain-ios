#!/bin/sh

FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift')
[ -z "$FILES" ] && exit 0

REPO_ROOT=$(git rev-parse --show-toplevel)
TMPDIR_PATH=$(mktemp -d)
trap "rm -rf '$TMPDIR_PATH'" EXIT

# For each staged Swift file: extract the index snapshot to a temp file,
# format/lint it there, then write the result back to the index only.
# The working tree is never touched — no stash, no conflicts.
echo "$FILES" | while IFS= read -r FILE; do
    [ -z "$FILE" ] && continue
    TMPFILE="$TMPDIR_PATH/$(basename "$FILE")"

    git show ":$FILE" > "$TMPFILE"

    swiftformat --config "$REPO_ROOT/.swiftformat" "$TMPFILE" 2>/dev/null
    swiftlint lint --fix --config "$REPO_ROOT/.swiftlint.yml" "$TMPFILE" 2>/dev/null

    ORIG_BLOB=$(git ls-files -s -- "$FILE" | awk '{print $2}')
    NEW_BLOB=$(git hash-object -w "$TMPFILE")
    if [ "$ORIG_BLOB" != "$NEW_BLOB" ]; then
        MODE=$(git ls-files -s -- "$FILE" | awk '{print $1}')
        git update-index --cacheinfo "$MODE,$NEW_BLOB,$FILE"
    fi
done
